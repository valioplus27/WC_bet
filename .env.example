# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# Supabase project settings (Project Settings > API in the Supabase dashboard)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Server-side only (used by Supabase Edge Functions, NOT exposed to the browser) ---
# Set these as Supabase Edge Function secrets, e.g.:
#   supabase secrets set FOOTBALL_DATA_API_KEY=xxxx
# Free API key from https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your-football-data-org-api-key

# The football-data.org competition code for the 2026 World Cup
FOOTBALL_DATA_COMPETITION_CODE=WC

# Service role key (Project Settings > API > service_role secret).
# Required by the sync Edge Function to write match/standings data and bypass RLS.
# NEVER expose this in frontend code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://your-project-ref.supabase.co
